# ============================================================================
# CHETTINAD CARE — COMPOSE ENVIRONMENT REFERENCE
# ============================================================================
# Copy this file to .env.compose and fill in real values.
# This stack is for a restricted web pilot backed by PostgreSQL.
# ============================================================================

# --- Node.js Runtime ---
NODE_ENV=production
APP_ENV=restricted_web_pilot
PORT=3001

# --- PostgreSQL Database ---
POSTGRES_USER=chettinad
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_DB_PASSWORD
POSTGRES_DB=chettinad_pilot

# --- Backend Database Connection ---
DB_DIALECT=postgres
DATABASE_URL=postgres://chettinad:CHANGE_THIS_SECURE_DB_PASSWORD@db:5432/chettinad_pilot
DATABASE_SSL=false
PGPOOL_MAX=10

# --- JWT Authentication ---
# MUST be a cryptographically random string of at least 32 characters.
# Generate with: openssl rand -hex 32
# NEVER use the default value in production.
JWT_SECRET=CHANGE_THIS_TO_A_CRYPTOGRAPHICALLY_RANDOM_32_PLUS_CHAR_STRING

# --- Refresh Cookie Settings ---
# Vercel + Railway / Render on different domains usually need:
# SameSite=None + Secure=true
COOKIE_SAME_SITE=none
COOKIE_SECURE=true
COOKIE_DOMAIN=

# --- CORS ---
# Set to the exact origin of the frontend (no trailing slash)
# Example: https://chettinad-pilot.yourdomain.com
CORS_ORIGIN=https://CHANGE_THIS_TO_YOUR_PILOT_DOMAIN

# --- Bootstrap Admin ---
# Required for the first deploy so you can sign in and create staff users.
BOOTSTRAP_ADMIN_ID=pilot_admin
BOOTSTRAP_ADMIN_NAME=Pilot Admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_THIS_BOOTSTRAP_ADMIN_PASSWORD

# --- Activation Delivery ---
# Staff-authenticated endpoints can return the activation code once so it can
# be shared with the patient over phone/WhatsApp during the pilot.
ACTIVATION_OTP_DELIVERY=api_response
