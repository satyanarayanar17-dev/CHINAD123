# ============================================================================
# CHETTINAD CARE — FRONTEND ENVIRONMENT REFERENCE
# ============================================================================
# Vite reads this file automatically during local builds and local dev.
# ============================================================================

# For local dev, leave VITE_API_BASE_URL blank to use the Vite proxy.
# For deployed frontends (for example Vercel), set this to your backend URL
# including the /api/v1 suffix.
VITE_API_BASE_URL=

# Local-only proxy target used when VITE_API_BASE_URL is blank.
VITE_DEV_API_PROXY_TARGET=http://localhost:3001
