# ============================================================================
# CHETTINAD CARE — BACKEND ENVIRONMENT REFERENCE
# ============================================================================
# Copy this file to .env and fill in real values for local dev.
# For Docker deployment, use .env.compose instead.
# ============================================================================

# --- Runtime Mode ---
# Options: development, production
NODE_ENV=development

# --- App Deployment Context ---
# Options: local_dev, local_pilot, restricted_web_pilot
APP_ENV=local_dev

# --- Server ---
PORT=3001

# --- Database ---
# For SQLite local dev (default):
DB_DIALECT=sqlite

# For PostgreSQL local dev/pilot:
# DB_DIALECT=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/chettinad_dev

# --- JWT Secret ---
# For local_dev: any string (fallback used if not set, with warning)
# For local_pilot and above: MUST BE SET. min 32 chars.
# Generate: openssl rand -hex 32
JWT_SECRET=

# --- CORS ---
# For local dev: leave unset (defaults to '*')
# For local_pilot: set to http://localhost:5173 or your dev origin
CORS_ORIGIN=

# --- Pilot Auth Bypass (LOCAL DEV ONLY) ---
# true = staff users without a password_hash can login without a password
# MUST be false or absent for local_pilot and restricted_web_pilot
PILOT_AUTH_BYPASS=true
