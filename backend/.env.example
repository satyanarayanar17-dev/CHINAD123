# ============================================================================
# CHETTINAD CARE — BACKEND ENVIRONMENT REFERENCE
# ============================================================================
# Local development defaults to SQLite. Restricted web pilot / production must
# use PostgreSQL and will refuse to boot on SQLite.
# ============================================================================

# Runtime
NODE_ENV=development
APP_ENV=local_dev
PORT=3001

# Database
DB_DIALECT=sqlite
SQLITE_PATH=verification.db

# PostgreSQL mode
# DB_DIALECT=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/chettinad_care
DATABASE_URL=
DATABASE_SSL=false
PGPOOL_MAX=10

# Auth
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Refresh cookie/session settings
# For same-site frontend+backend under one registrable domain, prefer:
# COOKIE_SAME_SITE=lax
# For different sites (for example Vercel + Railway default domains), use:
# COOKIE_SAME_SITE=none and COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_DOMAIN=

# CORS
# Leave blank for local dev. In restricted_web_pilot set the exact frontend
# origin, or a comma-separated list of allowed origins.
CORS_ORIGIN=

# Patient activation code delivery
# local_dev: api_response is convenient for manual testing
# restricted_web_pilot: api_response is the lightest-weight option if staff
# need to read and manually share a code with the patient.
ACTIVATION_OTP_DELIVERY=api_response

# Bootstrap admin
# Set these for the first pilot deploy. If an ADMIN user already exists, the
# backend leaves it unchanged.
BOOTSTRAP_ADMIN_ID=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_PASSWORD=

# Local-only helpers
PILOT_AUTH_BYPASS=true
ALLOW_SEED_RESET=true
